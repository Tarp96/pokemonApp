# ----------------------------------
# PokéVerse Environment Variables
# ----------------------------------

# PokeAPI Base URL (optional)
VITE_POKEAPI_BASE_URL=https://pokeapi.co/api/v2

# Enable Firebase features:
# true  = Auth, favourites, profiles, purchases
# false = Browse-only demo mode
VITE_ENABLE_FIREBASE=true

# ----------------------------------
# Firebase Config
# Required when VITE_ENABLE_FIREBASE=true
# ----------------------------------

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=